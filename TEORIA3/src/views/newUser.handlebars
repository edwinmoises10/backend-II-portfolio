<div class="container my-5">
  <div class="row justify-content-center">
    <div class="col-xl-10">
      <form class="row g-3 needs-validation p-4 border rounded shadow-sm bg-light" novalidate>

        <div class="col-md-4">
          <label for="firstname" class="form-label">Nombre</label>
          <input type="text" class="form-control" id="firstname" required>
          <div class="valid-feedback">¡Se ve bien!</div>
          <div class="invalid-feedback">Por favor, ingresa tu nombre.</div>
        </div>

        <div class="col-md-4">
          <label for="lastname" class="form-label">Apellido</label>
          <input type="text" class="form-control" id="lastname" required>
          <div class="valid-feedback">¡Se ve bien!</div>
          <div class="invalid-feedback">Por favor, ingresa tu apellido.</div>
        </div>

        <div class="col-md-4">
          <label for="email" class="form-label">Nombre de usuario</label>
          <div class="input-group has-validation">
            <span class="input-group-text" id="inputGroupPrepend">@</span>
            <input type="text" class="form-control" id="email" aria-describedby="inputGroupPrepend" required>
            <div class="invalid-feedback">Por favor, elige un nombre de usuario.</div>
          </div>
        </div>

        <div class="col-md-6">
          <label for="city" class="form-label">Ciudad</label>
          <input type="text" class="form-control" id="city" required>
          <div class="invalid-feedback">Por favor, ingresa una ciudad válida.</div>
        </div>

        <div class="col-md-6">
          <label for="password" class="form-label">Password</label>
          <input type="password" class="form-control" id="password" required>
          <div class="invalid-feedback">Por favor, ingresa tu contraseña.</div>
        </div>

        <div class="col-md-3">
          <label for="stateValue" class="form-label">Provincia</label>
          <select class="form-select" id="stateValue" required>
            <option selected disabled value="">Selecciona...</option>
            <option value="pichincha">Pichincha</option>
            <option value="azuay">Azuay</option>
            <option value="tungurahua">Tungurahua</option>
            <option value="guayas">Guayas</option>
          </select>
          <div class="invalid-feedback">Por favor, selecciona una provincia.</div>
        </div>

        <div class="col-md-3">
          <label for="zipCode" class="form-label">Código Postal</label>
          <input type="text" class="form-control" id="zipCode" required>
          <div class="invalid-feedback">Por favor, proporciona un código postal válido.</div>
        </div>

        <div class="col-12 my-3">
          <div class="form-check">
            <input class="form-check-input" type="checkbox" value="" id="invalidCheck" required>
            <label class="form-check-label" for="invalidCheck">
              Acepto los términos y condiciones
            </label>
            <div class="invalid-feedback">Debes aceptar los términos antes de continuar.</div>
          </div>
        </div>

        <div class="col-12 d-grid d-md-block text-end mt-4">
          <button class="btn btn-success px-4" id="saveUser" type="submit">Guardar</button>
        </div>

      </form>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="../public/newUser.js"></script>