<div class="container my-5">

    <div class="row">
        <div class="col-md-4 offset-md-4">

            <form>
                <h2 class="fw-bold">Login</h2>
                <div class=" mb-3">
                    <label for="email" class="form-label">Email</label>
                    <input type="email" class="form-control" id="email" aria-describedby="emailHelp">
                </div>
                <div class="mb-3">
                    <label for="password" class="form-label">Password</label>
                    <input type="password" class="form-control" id="password">
                </div>

                <div class="d-flex justify-content-around">
                    <button type="submit" class="btn btn-primary bg-success" id="btnLoginSession">Log in</button>

                </div>

                <div class="text-center mt-3 fs-7">
                    <span class="text-muted">¿No tienes cuenta?</span>
                    <a id='createCount' class="text-success fw-bold text-decoration-none ms-1">Regístrate</a>
                </div>

            </form>
        </div>
    </div>
</div>



<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="/public/login.js" defer></script>